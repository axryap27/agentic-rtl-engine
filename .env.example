# Copy to .env and fill in real values.  .env is gitignored — never commit credentials.

# OpenAI-compatible base URL of the LLM proxy (or https://api.anthropic.com/v1 for direct Anthropic)
LLM_BASE_URL=https://writingmate.ai/api/openai/v1

# API key for the proxy / provider
LLM_API_KEY=replace-with-your-key

# Default model.  Examples (the ~ prefix is part of the model ID on this proxy):
#   ~anthropic/claude-sonnet-latest
#   ~anthropic/claude-haiku-latest
#   ~google/gemini-pro-latest
LLM_MODEL=~anthropic/claude-sonnet-latest

# Anthropic API key for Agent 3 (Claude Agent SDK — separate from the proxy above).
# Agent 3 is a tool-using SDK agent that needs Anthropic's /v1/messages endpoint
# directly. Agent 1 and Agent 2 continue to use LLM_BASE_URL / LLM_API_KEY.
ANTHROPIC_API_KEY=replace-with-your-anthropic-key
