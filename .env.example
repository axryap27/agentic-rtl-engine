# Copy to .env and fill in real values.  .env is gitignored — never commit credentials.

# ============================================================
# PROXY CREDENTIALS — used by Agent 1 (and any other proxy LLM calls)
# ============================================================

# OpenAI-compatible base URL of the LLM proxy
LLM_BASE_URL=https://writingmate.ai/api/openai/v1

# API key for the proxy / provider (NOT an Anthropic key — this is for the proxy)
LLM_API_KEY=replace-with-your-proxy-key

# Default model routed through the proxy. Examples:
#   ~anthropic/claude-sonnet-latest
#   ~anthropic/claude-haiku-latest
#   ~google/gemini-pro-latest
LLM_MODEL=~anthropic/claude-sonnet-latest

# ============================================================
# AGENT 3 — SEPARATE CREDENTIAL (Claude Agent SDK / Anthropic direct)
# ============================================================
# This is a DIFFERENT key from LLM_API_KEY above.
# Agent 3 is a tool-using agent that calls Anthropic's /v1/messages endpoint
# DIRECTLY — it does NOT go through the proxy.
# The Anthropic SDK reads this env var by default.
#
# YOU MUST set this to a real Anthropic API key before Agent 3 will run.
# Stages 1 and 2 will still work without it.
#
# Get a key at: https://console.anthropic.com/settings/keys
#
ANTHROPIC_API_KEY=__AGENT3_CLAUDE_AGENT_SDK_KEY__NOT_CONFIGURED_YET__

# Optional: override the Claude model used by Agent 3 (default: claude-opus-4-5)
# AGENT3_MODEL=claude-sonnet-4-5
