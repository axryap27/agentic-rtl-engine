digraph FeasibleArchitecture {
    // Global graph settings
    rankdir=LR;
    bgcolor="white";
    labelloc="t";
    label=<<b><font point-size="24">Agentic RTL Engine — Feasible 3-Week Architecture</font></b>>;
    fontname="Helvetica";
    fontsize=24;
    nodesep=0.30;
    ranksep=0.55;
    splines=spline;
    compound=true;
    pad=0.5;
    newrank=true;

    // Default node style
    node [
        fontname="Helvetica",
        fontsize=11,
        style="rounded,filled",
        shape=box,
        fillcolor="white",
        color="#333333",
        penwidth=1.2,
        margin="0.18,0.12"
    ];

    // Default edge style
    edge [
        fontname="Helvetica",
        fontsize=10,
        color="#222222",
        arrowsize=0.85,
        penwidth=1.3
    ];

    //========================================================================
    // Boundary artifacts (cylinder)
    //========================================================================
    nl_spec      [shape=cylinder, style="filled", fillcolor="#ECECEC", color="#555555", label="NL Spec", fontsize=12];
    tla_spec     [shape=cylinder, style="filled", fillcolor="#ECECEC", color="#555555", label="TLA+\nFormal Spec", fontsize=12];
    pluscal      [shape=cylinder, style="filled", fillcolor="#ECECEC", color="#555555", label="Verified\nPlusCal Impl", fontsize=12];
    verilog_art  [shape=cylinder, style="filled", fillcolor="#ECECEC", color="#555555", label="Synthesizable\nVerilog", fontsize=12];
    eval_report  [shape=cylinder, style="filled", fillcolor="#ECECEC", color="#555555", label="Evaluation\nReport", fontsize=12];

    //========================================================================
    // STAGE 1 — Formalization (light blue)
    //========================================================================
    subgraph cluster_stage1 {
        label=<<b>Stage 1 — Formalization</b>>;
        style="rounded,filled";
        fillcolor="#DCE9F7";
        color="#5B8BC1";
        penwidth=1.4;
        fontname="Helvetica";
        fontsize=14;
        labelloc="t";
        labeljust="l";
        margin=16;

        s1_claude   [label="Claude\n(TLA+ Generation)"];
        s1_sany     [label="tla2sany\n(Syntax Check)"];
        s1_tlc      [label="TLC\n(Invariant\nModel Check)"];

        s1_claude -> s1_sany;
        s1_sany   -> s1_tlc;

        s1_tlc -> s1_claude [
            style="dashed",
            color="#777777",
            fontcolor="#555555",
            label=<<i>counterexample /<br/>syntax error</i>>,
            constraint=false,
            arrowsize=0.7
        ];
    }

    //========================================================================
    // STAGE 2 — Verified Refinement (light green)
    //========================================================================
    subgraph cluster_stage2 {
        label=<<b>Stage 2 — Verified Refinement</b>>;
        style="rounded,filled";
        fillcolor="#DDEFD9";
        color="#6FA864";
        penwidth=1.4;
        fontname="Helvetica";
        fontsize=14;
        labelloc="t";
        labeljust="l";
        margin=16;

        s2_claude   [label="Claude\n(PlusCal Generation)"];
        s2_pcal     [label="pcal.trans\n(PlusCal -> TLA+\nTranslator)"];
        s2_tlc      [label="TLC\n(Refinement Check\nvia INSTANCE)"];

        s2_claude -> s2_pcal;
        s2_pcal   -> s2_tlc;

        s2_tlc -> s2_claude [
            style="dashed",
            color="#777777",
            fontcolor="#555555",
            label=<<i>refinement<br/>counterexample</i>>,
            constraint=false,
            arrowsize=0.7
        ];
    }

    //========================================================================
    // STAGE 3 — Codegen (light yellow)
    //========================================================================
    subgraph cluster_stage3 {
        label=<<b>Stage 3 — Codegen</b>>;
        style="rounded,filled";
        fillcolor="#FBF1C8";
        color="#C9A227";
        penwidth=1.4;
        fontname="Helvetica";
        fontsize=14;
        labelloc="t";
        labeljust="l";
        margin=16;

        s3_claude    [label="Claude\n(Verilog Generation)"];
        s3_verilator [label="Verilator\n(Lint)"];
        s3_iverilog  [label="iverilog\n(Simulation,\nauto-testbench)"];

        s3_claude    -> s3_verilator;
        s3_verilator -> s3_iverilog;

        s3_iverilog -> s3_claude [
            style="dashed",
            color="#777777",
            fontcolor="#555555",
            label=<<i>lint / sim<br/>errors</i>>,
            constraint=false,
            arrowsize=0.7
        ];
    }

    //========================================================================
    // STAGE 4 — Evaluation (light pink)
    //========================================================================
    subgraph cluster_stage4 {
        label=<<b>Stage 4 — Evaluation</b>>;
        style="rounded,filled";
        fillcolor="#F9D9E2";
        color="#C26F8E";
        penwidth=1.4;
        fontname="Helvetica";
        fontsize=14;
        labelloc="t";
        labeljust="l";
        margin=16;

        s4_yosys   [label="Yosys\n(Synthesis:\narea, FF count,\ncritical path)"];
        s4_veval   [label="VerilogEval\n(Functional\nBenchmark)"];
        s4_claude  [label="Claude\n(Demo Summary)"];

        s4_yosys -> s4_veval;
        s4_veval -> s4_claude;
    }

    //========================================================================
    // Inter-stage forward flow (boundary artifacts in pipeline)
    //========================================================================
    nl_spec     -> s1_claude    [lhead=cluster_stage1, penwidth=1.6];
    s1_tlc      -> tla_spec     [ltail=cluster_stage1, penwidth=1.6];
    tla_spec    -> s2_claude    [lhead=cluster_stage2, penwidth=1.6];
    s2_tlc      -> pluscal      [ltail=cluster_stage2, penwidth=1.6];
    pluscal     -> s3_claude    [lhead=cluster_stage3, penwidth=1.6];
    s3_iverilog -> verilog_art  [ltail=cluster_stage3, penwidth=1.6];
    verilog_art -> s4_yosys     [lhead=cluster_stage4, penwidth=1.6];
    s4_claude   -> eval_report  [ltail=cluster_stage4, penwidth=1.6];
}
